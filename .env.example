# --- Telegram ---
# Get a bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user IDs allowed to talk to Higgins.
# Get your ID from @userinfobot on Telegram.
TELEGRAM_ALLOWED_USER_IDS=
# The user ID scheduled messages should be sent to.
TELEGRAM_PRIMARY_USER_ID=

# --- LLM ---
# Supports Ollama and any OpenAI-compatible server (llama.cpp, vLLM, LM Studio, etc.)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest
# API format: "ollama" (native), "openai" (OpenAI-compatible), or "auto" (detect)
# OLLAMA_API_FORMAT=auto

# --- Higgins ---
HIGGINS_NAME=Higgins
HIGGINS_TIMEZONE=America/New_York
HIGGINS_HISTORY_TURNS=10

# Comma-separated list of enabled skill directory names under skills/.
# Leave empty to enable every skill that's present.
HIGGINS_SKILLS=calendar,notes,schedule,weather
